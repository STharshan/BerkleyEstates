{
  "name": "berkleyestates",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && react-snap",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "reactSnap": {
    "source": "dist",
    "include": [
      "/",
      "/homeowners",
      "/let",
      "/property-management",
      "/maintenance",
      "/sell-berkley-estate",
      "/about",
      "/contact",
      "/privacy-policy",
      "/complaints",
      "/sell-discreetly",
      "/terms",
      "/valuation",
      "/properties",
      "/property/the-moor",
      "/property/cotes-road",
      "/property/workhouse-lane",
      "/property/manor-view-close",
      "/property/moira-road-swadlincote",
      "/property/iris-close-appleby-magna",
      "/property/ticknall-road",
      "/property/mill-street",
      "/property/potter-street",
      "/property/hinckley-road",
      "/property/rookery-close-kibworth-2"
    ],
    "skipThirdPartyRequests": true,
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ]
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@tailwindcss/vite": "^4.2.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.14.0",
    "react-router-hash-link": "^2.4.3",
    "swiper": "^12.1.3",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "react-snap": "^1.23.0",
    "vite": "^8.0.4",
    "vite-plugin-sitemap": "^0.8.2"
  }
}
